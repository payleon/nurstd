modules = ["nodejs-20", "python-3.11", "web"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["gh", "imagemagick", "jq", "nano"]

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "node dist/index.js"]
build = ["sh", "-c", "npm install && npm run build && mkdir -p dist/utils && cp server/utils/nursing_resources.json dist/utils/"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Build and Deploy"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Production Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Secure Production Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Development Server"

[[workflows.workflow]]
name = "Production Build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow]]
name = "Secure Production Build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && node frontend-obfuscate.js && cp -r published dist/ && cp public/sitemap.xml dist/ && cp public/robots.txt dist/ && echo \"Secure production build with frontend obfuscation completed!\""

[[workflows.workflow]]
name = "Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Build and Deploy"
author = 42204270
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p dist/utils"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cp server/utils/nursing_resources.json dist/utils/"
